{
	"name": "@x_gegis_library/toggle-card",
	"version": "0.1.0",
	"private": false,
	"description": "A fully custom toggle-list card for ServiceNow Next Experience (UI Builder). A titled card with on/off toggle rows, driven by a JSON array.",
	"keywords": [
		"ServiceNow",
		"Next Experience UI Component",
		"toggle",
		"switch",
		"card"
	],
	"readme": "./README.md",
	"engines": {
		"node": ">=22"
	},
	"module": "src/index.js",
	"scripts": {
		"develop": "snc ui-component develop --open",
		"deploy": "snc ui-component deploy",
		"test": "snc ui-component test",
		"develop:au": "snc ui-component develop --open -p australia"
	},
	"dependencies": {
		"@servicenow/sass-kit": "latest",
		"@servicenow/ui-core": "24.1.1",
		"@servicenow/ui-renderer-snabbdom": "24.1.1"
	},
	"devDependencies": {
		"@babel/runtime": "7.25.7",
		"ajv": "^6.12.6",
		"sass": "1.53.0"
