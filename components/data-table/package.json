{
	"name": "@x_gegis_library/data-table",
	"version": "0.1.0",
	"private": false,
	"description": "A configurable record list / data table for ServiceNow Next Experience (UI Builder): give it a table name and an encoded query and it loads the matching records over the Table API and renders them in a paginated, OOTB-style table with a status pill and per-row Edit / Duplicate / Delete actions. Emits row + action events for the page to bind.",
	"keywords": [
		"ServiceNow",
		"Next Experience UI Component",
		"table",
		"list",
		"data"
	],
	"readme": "./README.md",
	"engines": {
		"node": ">=22"
	},
	"module": "src/index.js",
	"scripts": {
		"develop": "snc ui-component develop --open",
		"deploy": "snc ui-component deploy",
		"test": "snc ui-component test",
		"develop:au": "snc ui-component develop --open -p australia"
	},
	"dependencies": {
		"@servicenow/sass-kit": "latest",
		"@servicenow/ui-core": "24.1.1",
		"@servicenow/ui-effect-http": "24.1.1",
		"@servicenow/ui-renderer-snabbdom": "24.1.1"
	},
	"devDependencies": {
		"@babel/runtime": "7.25.7",
		"@servicenow/now-icon": "latest",
		"@servicenow/now-loader": "latest",
		"@servicenow/now-pagination-control": "latest",
		"ajv": "^6.12.6",
		"sass": "1.53.0"
	},
	"publishConfig": {
		"registry": "https://npm.pkg.github.com/"
	}
}
