{
	"name": "@x_gegis_library/dynamic-form",
	"version": "0.1.0",
	"private": false,
	"description": "An OOTB-style record form for ServiceNow Next Experience (UI Builder): configure a table, sys_id and view; the component loads field metadata, choices and the form layout over the Table API and PATCHes changes on Save / autosave. Read-only and Autosave toggles included.",
	"keywords": [
		"ServiceNow",
		"Next Experience UI Component",
		"form",
		"metadata",
		"dynamic"
	],
	"readme": "./README.md",
	"engines": {
		"node": ">=22"
	},
	"module": "src/index.js",
	"scripts": {
		"develop": "snc ui-component develop --open",
		"deploy": "snc ui-component deploy",
		"test": "snc ui-component test",
		"develop:au": "snc ui-component develop --open -p australia"
	},
	"dependencies": {
		"@servicenow/sass-kit": "latest",
		"@servicenow/ui-core": "24.1.1",
		"@servicenow/ui-effect-http": "24.1.1",
		"@servicenow/ui-renderer-snabbdom": "24.1.1"
	},
	"devDependencies": {
		"@babel/runtime": "7.25.7",
		"ajv": "^6.12.6",
		"sass": "1.53.0"
	},
	"publishConfig": {
		"registry": "https://npm.pkg.github.com/"
	}
}
